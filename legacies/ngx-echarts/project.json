{
  "name": "ngx-echarts",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "legacies/ngx-echarts/src",
  "prefix": "metad-ocap",
  "tags": [],
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "@nx/angular:package",
      "outputs": [
        "{workspaceRoot}/dist/{projectRoot}"
      ],
      "options": {
        "project": "legacies/ngx-echarts/ng-package.json"
      },
      "configurations": {
        "production": {
          "tsConfig": "legacies/ngx-echarts/tsconfig.lib.prod.json"
        },
        "development": {
          "tsConfig": "legacies/ngx-echarts/tsconfig.lib.json"
        }
      },
      "defaultConfiguration": "production"
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": [
        "{workspaceRoot}/coverage/{projectRoot}"
      ],
      "options": {
        "jestConfig": "legacies/ngx-echarts/jest.config.ts"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": [
        "{options.outputFile}"
      ],
      "options": {
        "lintFilePatterns": [
          "legacies/ngx-echarts/**/*.ts",
          "legacies/ngx-echarts/**/*.html"
        ]
      }
    }
  }
}
