{
  "name": "adapter",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "legacies/adapter/src",
  "targets": {
    "build": {
      "executor": "@nx/rollup:rollup",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/legacies/adapter",
        "main": "legacies/adapter/src/index.ts",
        "tsConfig": "legacies/adapter/tsconfig.lib.json",
        "project": "legacies/adapter/package.json",
        "buildLibsFromSource": false,
        "assets": [
          {
            "glob": "README.md",
            "input": ".",
            "output": "."
          }
        ],
        "compiler": "swc",
        "format": ["cjs", "esm"],
        "external": [
          "@xpert-ai/contracts",
          "@xpert-ai/plugin-sdk"
        ]
      }
    },
    "publish": {
      "command": "node tools/scripts/publish.mjs adapter {args.ver} {args.tag}",
      "dependsOn": ["build"]
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"],
      "options": {
        "lintFilePatterns": ["legacies/adapter/**/*.ts", "legacies/adapter/package.json"]
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/legacies/adapter"],
      "options": {
        "jestConfig": "legacies/adapter/jest.config.ts"
      }
    }
  },
  "tags": []
}
