{
  "extends": ["../../.eslintrc.json"],
  "ignorePatterns": ["!**/*"],
  "overrides": [
    {
      "files": ["*.ts"],
      "extends": ["plugin:@nx/angular", "plugin:@angular-eslint/template/process-inline-templates"],
      "rules": {
        "@angular-eslint/directive-selector": "off",
        "@angular-eslint/component-selector": [
          "error",
          {
            "type": "element",
            "prefix": "xp|z",
            "style": "kebab-case"
          }
        ],
        "no-restricted-imports": [
          "warn",
          {
            "patterns": [
              {
                "group": ["@xpert-ai/headless-ui/*", "packages/ui/src/**"],
                "message": "Import UI symbols from the @xpert-ai/headless-ui root entrypoint instead of UI deep paths."
              },
              {
                "group": [
                  "@xpert-ai/ocap-angular",
                  "@xpert-ai/ocap-angular/*",
                  "@xpert-ai/ocap-core",
                  "@metad/ocap-core",
                  "@xpert-ai/story",
                  "@xpert-ai/story/*",
                  "packages/angular/**",
                  "packages/core/**",
                  "libs/story-angular/**"
                ],
                "message": "packages/ui is the base UI library and must not depend on OCAP, Story, semantic model, or angular business packages."
              }
            ]
          }
        ]
      }
    },
    {
      "files": ["*.html"],
      "extends": ["plugin:@nx/angular-template"],
      "rules": {}
    },
    {
      "files": ["*.json"],
      "parser": "jsonc-eslint-parser",
      "rules": {
        "@nx/dependency-checks": [
          "error",
          {
            "ignoredFiles": ["{projectRoot}/eslint.config.{js,cjs,mjs}"]
          }
        ]
      }
    }
  ]
}
