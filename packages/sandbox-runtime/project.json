{
  "name": "sandbox-runtime",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/sandbox-runtime",
  "projectType": "library",
  "tags": ["scope:platform", "type:runtime-images"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/dist/packages/sandbox-runtime"],
      "options": {
        "command": "node packages/sandbox-runtime/scripts/verify-catalog.mjs --output dist/packages/sandbox-runtime/build-matrix.json --definitions-output dist/packages/sandbox-runtime/runtime-definitions.json",
        "cwd": "."
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "node packages/sandbox-runtime/scripts/verify-catalog.mjs",
          "node packages/sandbox-runtime/images/browser/tests/runner-host.test.mjs",
          "node packages/sandbox-runtime/images/browser-video/tests/runtime-contract.test.mjs"
        ],
        "parallel": false,
        "cwd": "."
      }
    }
  }
}
