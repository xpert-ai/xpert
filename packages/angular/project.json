{
  "name": "ocap-angular",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/angular/src",
  "prefix": "metad-ocap",
  "tags": [],
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "@nx/angular:package",
      "outputs": [
        "{workspaceRoot}/dist/{projectRoot}"
      ],
      "options": {
        "project": "packages/angular/ng-package.json"
      },
      "configurations": {
        "production": {
          "tsConfig": "packages/angular/tsconfig.lib.prod.json"
        },
        "development": {
          "tsConfig": "packages/angular/tsconfig.lib.json"
        }
      },
      "defaultConfiguration": "production",
      "dependsOn": [
        {
          "projects": [
            "ngx-echarts"
          ],
          "target": "build",
          "params": "ignore"
        },
        {
          "projects": [
            "duckdb"
          ],
          "target": "build",
          "params": "ignore"
        },
        {
          "projects": [
            "echarts"
          ],
          "target": "build",
          "params": "ignore"
        }
      ]
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": [
        "{workspaceRoot}/coverage/{projectRoot}"
      ],
      "options": {
        "jestConfig": "packages/angular/jest.config.ts"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": [
        "{options.outputFile}"
      ],
      "options": {
        "lintFilePatterns": [
          "packages/angular/**/*.ts",
          "packages/angular/**/*.html"
        ]
      }
    }
  }
}
