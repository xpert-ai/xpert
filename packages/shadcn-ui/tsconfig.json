{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "../../dist/out-tsc/packages/shadcn-ui",
    "declaration": true,
    "declarationMap": true,
    "jsx": "react-jsx",
    "module": "esnext",
    "moduleResolution": "node",
    "types": ["react", "react-dom"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "exclude": ["dist", "node_modules", "**/*.spec.ts", "**/*.spec.tsx"]
}
