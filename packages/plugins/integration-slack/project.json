{
  "name": "integration-slack",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/plugins/integration-slack/src",
  "projectType": "library",
  "release": {
    "version": {
      "generatorOptions": {
        "packageRoot": "dist/{projectRoot}",
        "currentVersionResolver": "git-tag"
      }
    }
  },
  "tags": [],
  "targets": {
    "build": {
      "executor": "@nx/rollup:rollup",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/packages/plugins/integration-slack",
        "main": "packages/plugins/integration-slack/src/index.ts",
        "tsConfig": "packages/plugins/integration-slack/tsconfig.lib.json",
        "assets": [],
        "project": "packages/plugins/integration-slack/package.json",
        "compiler": "swc",
        "format": ["cjs", "esm"],
        "external": [
          "@metad/contracts",
          "@metad/server-core",
          "@nestjs/config",
          "@nestjs/common",
          "@nestjs/core",
          "@nestjs/typeorm",
          "@nestjs/microservices",
          "@xpert-ai/plugin-sdk",
          "typeorm",
          "aws-sdk",
          "moment",
          "multer-s3",
          "kafkajs",
          "amqplib",
          "mqtt",
          "nats",
          "uuid",
          "zod"
        ]
      }
    },
    "nx-release-publish": {
      "options": {
        "packageRoot": "dist/{projectRoot}"
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "packages/plugins/integration-slack/jest.config.ts"
      }
    }
  }
}
